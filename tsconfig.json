{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "app/**/*.mts",
    "packages/ui-web/**/*.ts",
    "packages/ui-web/**/*.tsx",
    "packages/tokens/**/*.ts",
    "packages/figma-sync/**/*.ts",
    "packages/figma-sync/**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "packages/ui-native",
    "packages/mobile",
    "packages/shared"
  ]
}
